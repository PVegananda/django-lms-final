# =============================================================================
# Django LMS Final Project — Environment Variables Template
# Salin file ini menjadi .env lalu isi nilainya
#   cp .env.example .env
# =============================================================================

# Django
DJANGO_SECRET_KEY=ganti-dengan-secret-key-yang-kuat-dan-random
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=lms_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=database
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379

# MongoDB
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=lms_analytics

# Celery / RabbitMQ
CELERY_BROKER_URL=amqp://admin:password123@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/2
